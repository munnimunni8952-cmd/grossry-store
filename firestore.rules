rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validation Helpers ---

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'category', 'price', 'image', 'description', 'unit']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.image is string && data.image.size() <= 2000 &&
             data.description is string && data.description.size() <= 5000 &&
             data.unit is string && data.unit.size() <= 50;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['id', 'name', 'image', 'icon']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.image is string && data.image.size() <= 2000 &&
             data.icon is string && data.icon.size() <= 100;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             (data.get('isAdmin', false) == false); // Users cannot make themselves admin
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'phone', 'address', 'items', 'totalAmount', 'status', 'paymentMethod', 'createdAt']) &&
             (data.get('userId', null) == null || data.userId == request.auth.uid) &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['pending', 'processed', 'shipped', 'delivered', 'cancelled'] &&
             data.items is list && data.items.size() > 0 &&
             data.createdAt == request.time &&
             data.get('notes', '') is string && data.get('notes', '').size() <= 1000;
    }

    // --- Collection Rules ---

    match /products/{productId} {
      allow read: if true;
      allow write: if false; // Only admin via console for now
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users can't list other users
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'phoneNumber', 'address']);
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isValidOrder(incoming());
      allow update: if false; // Orders are immutable for users for now
    }
  }
}
