{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A food product available for purchase.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "image": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "isTrending": { "type": "boolean" },
        "isOffer": { "type": "boolean" },
        "unit": { "type": "string" }
      },
      "required": ["id", "name", "category", "price", "image", "description", "unit"]
    },
    "Category": {
      "title": "Category",
      "description": "A product category.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "image": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["id", "name", "image", "icon"]
    },
    "User": {
      "title": "User",
      "description": "User profile data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "isAdmin": { "type": "boolean" }
      },
      "required": ["uid", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processed", "shipped", "delivered", "cancelled"] },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "customerName", "phone", "address", "items", "totalAmount", "status", "paymentMethod", "createdAt"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Collection of all products."
    },
    "categories": {
      "schema": "Category",
      "description": "Collection of product categories."
    },
    "users": {
      "schema": "User",
      "description": "User profiles and data."
    },
    "orders": {
      "schema": "Order",
      "description": "Customer orders."
    }
  }
}
