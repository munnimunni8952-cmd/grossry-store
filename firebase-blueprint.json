{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "Product": {
      "title": "Product",
      "description": "Product details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "User order",
      "type": "object",
      "properties": {
        "status": { "type": "string" },
        "userId": { "type": "string" }
      }
    }
  },
  "firestore": {
    "categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Categories collection"
    },
    "products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Products collection"
    },
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Users collection"
    },
    "orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Orders collection"
    }
  }
}
